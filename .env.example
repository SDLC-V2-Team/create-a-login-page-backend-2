# Server
PORT=3000
NODE_ENV=development

# JWT (ADR-001: HS256)
# Use a long, random secret in production (>= 32 bytes)
JWT_SECRET=change-me-to-a-long-random-secret-value
JWT_EXPIRES_IN=1h

# bcrypt (ADR-002: cost factor 12)
BCRYPT_COST=12

# PostgreSQL (ADR-003)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/loginpage
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=loginpage
